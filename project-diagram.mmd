%%{init: {'theme': 'base', 'themeVariables': {'clusterBkg': '#F8FAFC', 'clusterBorder': '#CBD5E1', 'edgeLabelBackground': '#F1F5F9', 'fontSize': '13px'}}}%%
flowchart TD

    classDef aws     fill:#FF9900,stroke:#B45309,color:#000,font-weight:bold
    classDef app     fill:#1D4ED8,stroke:#1E40AF,color:#fff,font-weight:bold
    classDef agent   fill:#7C3AED,stroke:#5B21B6,color:#fff,font-weight:bold
    classDef scanner fill:#DC2626,stroke:#991B1B,color:#fff,font-weight:bold
    classDef store   fill:#0891B2,stroke:#0E7490,color:#fff,font-weight:bold
    classDef ext     fill:#1F2937,stroke:#374151,color:#E5E7EB,font-weight:bold
    classDef cicd    fill:#059669,stroke:#047857,color:#fff,font-weight:bold
    classDef person  fill:#0F172A,stroke:#334155,color:#F8FAFC,font-weight:bold

    USER(["👤  User / Browser"]):::person

    %% ─────────────────────────────────────────────────────────────
    subgraph ENTRY ["  🌐  Entry Layer  "]
        ALB_FE["🔀  ALB — Frontend\nPublic · HTTPS · Port 80"]:::aws
        COGNITO["🔐  AWS Cognito\nUser Pools · JWT · OAuth 2.0"]:::aws
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph ECS ["  ☁️  ECS Fargate Cluster — docker-auditor  "]
        subgraph FE_SVC ["  📦  Frontend Service · 2 Tasks  "]
            FE["⚛️  Next.js 14\nApp Router · TypeScript\nTailwindCSS · shadcn/ui\nSentry Browser SDK"]:::app
        end
        subgraph BE_SVC ["  🔧  Backend Service · 2 Tasks  "]
            ALB_BE["🔀  ALB — Backend\nInternal · Port 8000"]:::aws
            BE["🐍  FastAPI · Python 3.12\nPydantic v2 · Uvicorn · HTTPX\nboto3 · OTEL SDK · Sentry SDK"]:::app
        end
        subgraph WK_SVC ["  🤖  Worker Service · 1 Task  "]
            WK["⚙️  Async Python Worker\nSQS Consumer Loop\nLangGraph Orchestrator\nOTEL SDK · Sentry SDK"]:::app
        end
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph QUEUE ["  📨  Message Queue  "]
        SQS["📬  SQS FIFO Queue\nscan-jobs.fifo\nMessageGroupId = repo_id · DLQ"]:::aws
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph SCAN ["  🔍  Security Scanning Layer  "]
        TRIVY["🛡️  Trivy — Local Binary\nvuln + secret scanners\nVuln DB baked into image\n--format json · --timeout 10m"]:::scanner
        LAM_TRIVY["λ  Trivy Lambda\nFallback — no binary\ntrivy-scanner-fn"]:::aws
        INSPECTOR["🔎  AWS Inspector v2\nECR Container CVE Scan\nManaged Scanner"]:::aws
        LAM_INSP["λ  Inspector Trigger\nStart / poll scan\ninspector-trigger-fn"]:::aws
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph AGENTS ["  🧠  AI Agent Pipeline — LangGraph State Machines  "]
        subgraph PARALLEL ["  ⟳  Parallel Execution  "]
            CVE["🔒  CVE Analyst\ncve_analyst.py\nEPSS · KEV · Regression"]:::agent
            BLOAT["📦  Bloat Detective\nbloat_detective.py\nLayer Analysis"]:::agent
            BASE["🏗️  Base Image Strategist\nbase_image_strategist.py\nUpgrade Recommendations"]:::agent
            COMP["✅  Compliance Checker\ncompliance_checker.py\nCIS · NIST · PCI-DSS"]:::agent
        end
        subgraph SEQUENTIAL ["  →  Sequential  "]
            DOPT["📝  Dockerfile Optimizer\ndockerfile_optimizer.py\nMulti-stage · Diff output"]:::agent
            RISK["📊  Risk Scorer\nrisk_scorer.py\nA–F Grade · CVSS · Top Actions"]:::agent
        end
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph DATA ["  💾  Data Layer  "]
        DDB[("🗄️  DynamoDB\n── scan-jobs\n── scan-results\n── users\n── repositories\n── user-credentials")]:::store
        S3[("🪣  S3 Bucket\nscan-reports/\nFull JSON · per scan_id")]:::store
        REDIS[("⚡  ElastiCache Redis\nWebSocket sessions\nProgress pub/sub\nConnection registry")]:::store
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph RT ["  📡  Real-time Progress Layer  "]
        WSAPI["🔌  API Gateway — WebSocket\n\$connect · \$disconnect · \$default"]:::aws
        LAM_WS["λ  WebSocket Handler\nconnect · disconnect · broadcast\nws-handler-fn"]:::aws
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph SUPPORT ["  🔧  AWS Supporting Infrastructure  "]
        SECRETS["🔑  Secrets Manager\nOpenAI Key · Sentry DSN\nGrafana Token · LangSmith Key"]:::aws
        SES["📧  AWS SES\nScan Completed Email\nHTML Template"]:::aws
        CW["📋  CloudWatch\nLogs · Log Groups\nAlarms · Dashboards"]:::aws
        IAM["🛡️  IAM Task Roles\nECR Pull · DDB · S3\nSQS · Secrets · SES"]:::aws
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph SAAS ["  🌍  External SaaS Services  "]
        OPENAI("🤖  OpenAI — GPT-4o\nAll 6 agents · temperature=0\nMax 40 000 token input"):::ext
        LANGSMITH("🔗  LangSmith\nLangGraph Run Tracing\nPrompt Versions"):::ext
        SENTRY_FE("🚨  Sentry — Frontend\nBrowser Errors · Performance"):::ext
        SENTRY_BE("🚨  Sentry — Backend\nPython Exceptions\nWorker Errors"):::ext
        GRAFANA("📈  Grafana Cloud\nOTLP Metrics + Traces\nDashboards · Alerts"):::ext
    end

    %% ─────────────────────────────────────────────────────────────
    subgraph CICD_BOX ["  🚀  CI / CD Pipeline  "]
        GH["⚙️  GitHub Actions\nci-cd.yml\nPR → Lint → Test → Build → Push → Deploy"]:::cicd
        TF["🏗️  Terraform — 13 Modules\nvpc · ecs · alb · ecr · cognito · dynamodb\nroute53 · waf · s3 · redis · sqs · ses · iam"]:::cicd
        subgraph ECR_ROW ["  📦  ECR Container Registries  "]
            ECR_FE["📦  ECR\nfrontend"]:::aws
            ECR_BE["📦  ECR\nbackend"]:::aws
            ECR_WK["📦  ECR\nworker"]:::aws
        end
    end

    %% ═══════════════════════════════════════════════════════════════
    %%  CONNECTIONS
    %% ═══════════════════════════════════════════════════════════════

    %% Entry
    USER        -->|"HTTPS"| ALB_FE
    USER        -->|"Login / Sign Up"| COGNITO
    ALB_FE      --> FE

    %% Frontend → Backend
    FE          -->|"REST  /api/v1/*"| ALB_BE
    FE         <-->|"WebSocket — real-time progress"| WSAPI
    FE          -->|"JS errors · performance"| SENTRY_FE
    ALB_BE      --> BE

    %% Backend
    BE          -->|"Verify JWT"| COGNITO
    BE          -->|"CRUD jobs & results"| DDB
    BE          -->|"Enqueue scan job"| SQS
    BE          -->|"Exceptions"| SENTRY_BE
    BE          -->|"OTLP spans & metrics"| GRAFANA
    BE          -->|"Structured logs"| CW

    %% WebSocket pub/sub
    WSAPI      <-->  LAM_WS
    LAM_WS     <-->|"Sessions · Connection IDs"| REDIS

    %% Worker entry
    SQS         -->|"Long poll"| WK
    WK          -->|"Read API keys"| SECRETS
    WK          -->|"Fetch previous scan"| DDB

    %% Scanners
    WK          -->|"subprocess · task-role auth"| TRIVY
    TRIVY       -.->|"fallback"| LAM_TRIVY
    WK          -->|"Invoke"| LAM_INSP
    LAM_INSP    -->|"ECR image scan"| INSPECTOR

    %% Agent fan-out (parallel)
    WK          -->|"trivy + inspector + prev_scan"| CVE
    WK          -->|"layer_data + manifest"| BLOAT
    WK          -->|"manifest"| BASE
    WK          -->|"manifest + trivy_results"| COMP

    %% Sequential pipeline
    CVE & BLOAT & BASE & COMP  -->|"findings[ ]"| DOPT
    DOPT        -->|"all_findings + dockerfile diff"| RISK

    %% LLM calls
    CVE & BLOAT & BASE & COMP & DOPT & RISK  -->|"ainvoke  gpt-4o"| OPENAI
    OPENAI      -.->|"run tracing"| LANGSMITH

    %% Results & notifications
    WK          -->|"store_scan_result"| DDB
    WK          -->|"upload_scan_report"| S3
    WK          -->|"publish_progress  10 → 100 %"| WSAPI
    WK          -->|"scan completed email"| SES
    WK          -->|"OTLP · agent durations · CVE counters"| GRAFANA
    WK          -->|"Structured logs"| CW

    %% CI/CD
    GH          -->|"docker build · push"| ECR_FE & ECR_BE & ECR_WK
    GH          -->|"ecs update-service"| ECS
    ECR_FE      -->|"image pull"| FE
    ECR_BE      -->|"image pull"| BE
    ECR_WK      -->|"image pull"| WK
    TF          -->|"terraform apply"| ECS & DATA & SUPPORT & RT & QUEUE
    IAM         -->|"grants permissions"| WK & BE
