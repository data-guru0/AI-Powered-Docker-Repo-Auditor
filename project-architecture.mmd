            pytest 8.2.2 · pytest-asyncio 0.23.7"]:::app
        end
    end

    %% ─── MESSAGE QUEUE ───────────────────────────────────────────────
    subgraph QUEUE_BOX ["  📨  Message Queue Layer  "]
        SQS["📬 SQS FIFO Queue
        docker-auditor-{env}-scan-jobs.fifo
        MessageGroupId = repo_id
        Visibility Timeout: 900s (15 min)
        Message Retention: 24 hours
        Deduplication: Content-based
        Long Poll Wait Time: 20s
        Max Message Size: 256 KB"]:::queue

        DLQ["💀 Dead-Letter Queue
        docker-auditor-{env}-scan-dlq.fifo
        Max Receive Count: 3 Retries
        Retention Period: 14 days
        CloudWatch Alarm on DLQ Depth
        SNS Email on Failed Jobs"]:::queue
    end

    %% ─── SECURITY SCANNING ───────────────────────────────────────────
    subgraph SCAN ["  🔍  Security Scanning Layer  "]
        TRIVY["🛡️ Trivy — Local Binary
        Vulnerability + Secret Scanning
        Vuln DB Baked into Docker Image
        --format json · --timeout 10m
        OS Packages + App Libraries
        Severity: CRITICAL HIGH MEDIUM LOW
        Reports: CVEs with fix versions"]:::scanner

        LAM_TRIVY["λ Trivy Lambda — Fallback
        trivy-scanner-fn
        Runtime: Python 3.12
        Memory: 1024 MB · Timeout: 300s
        VPC Private Subnets
        Trigger: if local binary fails"]:::aws

        INSPECTOR["🔎 AWS Inspector v2
        ECR Container CVE Scanning
        Managed CVE Database
        EPSS Risk Probability Scoring
        Active Exploitability Flags
        KEV — Known Exploited Vulns"]:::aws

        LAM_INSP["λ Inspector Trigger
        inspector-trigger-fn
        Start + Poll ECR Scan
        Runtime: Python 3.12 · 512 MB
        Timeout: 60s
        Returns: FindingsList JSON"]:::aws
    end

    %% ─── AI AGENT PIPELINE ───────────────────────────────────────────
    subgraph AGENTS ["  🧠  LangGraph AI Agent Pipeline  "]
        ORCH["🎯 Orchestrator
        orchestrator.py
        asyncio.gather — Parallel Phase
        State Machine: findings · dockerfile
        Progress: publish 10% → 100%
        Via WebSocket pub/sub · Redis"]:::agent

        subgraph PAR ["  ⟳  Phase 1 — Parallel Execution (asyncio.gather)  "]
            CVE["🔒 CVE Analyst
            cve_analyst.py
            EPSS Probability Scoring
            KEV — Known Exploited Vulns
            Patch Status · Regression Check
            CVSS-weighted Criticality Rank
            GPT-4o · temperature=0"]:::agent

            BLOAT["📦 Bloat Detective
            bloat_detective.py
            Layer-by-Layer Analysis
            Unneeded Package Detection
            Artifact Size Breakdown
            Size Reduction Recommendations
            GPT-4o · temperature=0"]:::agent

            BASE["🏗️ Base Image Strategist
            base_image_strategist.py
            Distroless Recommendations
            Alpine vs Ubuntu Comparison
            Multi-stage Build Guidance
            Cost + Security Trade-offs
            GPT-4o · temperature=0"]:::agent

            COMP["✅ Compliance Checker
            compliance_checker.py
            CIS Docker Benchmark
            NIST 800-53 Controls
            PCI-DSS Requirements
            Findings per Control
            GPT-4o · temperature=0"]:::agent
        end

        subgraph SEQ ["  →  Phase 2 — Sequential Pipeline  "]
            DOPT["📝 Dockerfile Optimizer
            dockerfile_optimizer.py
            Multi-stage Build Refactoring
            Layer Consolidation
            Build Cache Optimization
            Unified Diff Output
            GPT-4o · temperature=0"]:::agent

            RISK["📊 Risk Scorer
            risk_scorer.py
            A–F Letter Grade
            A=80–100 Green · B=60–79 Yellow
            C=40–59 Orange · D-F=0–39 Red
            CVSS-weighted Score
            Top 5 Actionable Fix Items
            GPT-4o · temperature=0"]:::agent
        end
    end

    %% ─── REAL-TIME LAYER ─────────────────────────────────────────────
    subgraph RT_BOX ["  📡  Real-time WebSocket Layer  "]
        WSAPI["🔌 API Gateway — WebSocket v2
        docker-auditor-{env}-ws
        Routes: $connect · $disconnect · $default
        Route Selection: $request.body.action
        Throttle: 1000 burst / 500 rate per sec
        Stage Auto-deploy · CloudWatch Logs
        HTTP_PROXY Integration → Backend ALB"]:::rt

        LAM_AUTH["λ WS JWT Authorizer
        ws-authorizer-fn
        Validates Cognito JWT on $connect
        Runtime: Python 3.12 · 128 MB
        Timeout: 10s · Inline Code
        Returns: Allow / Deny Policy Doc"]:::aws

        LAM_WS["λ WebSocket Handler
        ws-handler-fn
        connect · disconnect · broadcast
        Runtime: Python 3.12
        Stores Connection IDs in Redis
        Publishes Progress via Pub/Sub"]:::aws
    end

    %% ─── DATA LAYER ──────────────────────────────────────────────────
    subgraph DATA ["  💾  Data & Storage Layer  "]
        DDB[("🗄️ DynamoDB — On-demand Billing
        ─────────────────────────────
        scan-jobs Table
          PK: job_id (S)
          GSI: UserIdIndex (user_id, created_at)
          GSI: RepoIdIndex (repo_id, created_at)
          TTL: expires_at · PITR: 7-day
          KMS Encrypted
        ─────────────────────────────
        scan-results Table
          PK: job_id (S)
          GSI: RepoIdIndex (repoId, scanDate)
          PITR Enabled · KMS Encrypted
        ─────────────────────────────
        ws-connections Table
          PK: job_id + connection_id
          TTL: 1 hour auto-expiry
        ─────────────────────────────
        connections Table (legacy REST)")]:::store

        S3[("🪣 S3 — Scan Reports Bucket
        docker-auditor-{env}-scan-reports-{acct}
        Versioning: Enabled · KMS Encrypted
        Public Access: Fully Blocked
        ─────────────────────────────
        Lifecycle Policy:
          0–30d    → STANDARD Storage
          30–90d   → STANDARD_IA
          90–365d  → GLACIER Archive
          365d+    → Permanent Delete
        Multipart Abort: 7 days
        Force Destroy: true (non-prod)")]:::store

        REDIS[("⚡ ElastiCache Redis 7.0
        docker-auditor-{env}-redis
        Dev:  cache.t3.micro · 1 node
        Prod: cache.r6g.large · 2 nodes
        TLS In-transit · KMS At-rest
        maxmemory-policy: allkeys-lru
        notify-keyspace-events: Ex
        Multi-AZ: Yes (prod only)
        Backup: Daily at 04:00 UTC
        Use Cases:
          WebSocket Connection Registry
          Progress Pub/Sub (job → client)
          Session State Storage
        Port 6379")]:::store
    end

    %% ─── AWS SUPPORTING SERVICES ─────────────────────────────────────
    subgraph SUPPORT ["  🔧  AWS Supporting Services  "]
        SECRETS["🔑 Secrets Manager
        docker-auditor/{env}/
          openai-api-key (sk-proj-*)
          langsmith-api-key (lsv2_pt_*)
