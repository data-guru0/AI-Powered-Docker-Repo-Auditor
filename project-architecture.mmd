%%{init: {
  'theme': 'base',
  'themeVariables': {
    'background':          '#ffffff',
    'mainBkg':             '#ffffff',
    'clusterBkg':          '#F8FAFC',
    'clusterBorder':       '#94A3B8',
    'edgeLabelBackground': '#FEF9C3',
    'fontSize':            '13px',
    'fontFamily':          'Segoe UI, Inter, system-ui, sans-serif',
    'lineColor':           '#334155'
  }
}}%%
flowchart TD

    classDef aws     fill:#FF9900,stroke:#92400E,color:#000,font-weight:bold
    classDef app     fill:#1D4ED8,stroke:#1E3A8A,color:#fff,font-weight:bold
    classDef agent   fill:#7C3AED,stroke:#4C1D95,color:#fff,font-weight:bold
    classDef scanner fill:#DC2626,stroke:#7F1D1D,color:#fff,font-weight:bold
    classDef store   fill:#0E7490,stroke:#164E63,color:#fff,font-weight:bold
    classDef ext     fill:#1E293B,stroke:#0F172A,color:#E2E8F0,font-weight:bold
    classDef cicd    fill:#047857,stroke:#064E3B,color:#fff,font-weight:bold
    classDef person  fill:#0F172A,stroke:#334155,color:#F1F5F9,font-weight:bold
    classDef queue   fill:#B45309,stroke:#78350F,color:#fff,font-weight:bold
    classDef rt      fill:#0369A1,stroke:#0C4A6E,color:#fff,font-weight:bold

    USER(["👤 User / Browser"]):::person

    %% ── ENTRY ────────────────────────────────────────────────────────
    subgraph ENTRY ["  🌐  Edge & Entry  "]
        R53["🌍 Route 53\nDNS · ACM TLS"]:::aws
        WAF["🛡️ WAFv2\nOWASP · Rate Limit"]:::aws
        ALB_FE["🔀 ALB — Frontend\nPublic HTTPS"]:::aws
    end

    %% ── AUTH ─────────────────────────────────────────────────────────
    subgraph AUTH ["  🔐  Authentication  "]
        COGNITO["🔐 AWS Cognito\nUser Pools · JWT\nOAuth 2.0 · SRP"]:::aws
        AMPLIFY["📱 AWS Amplify\nAuth UI · Token Refresh\nFederated Identities"]:::aws
    end

    %% ── ECS FARGATE ──────────────────────────────────────────────────
    subgraph ECS ["  ☁️  ECS Fargate Cluster  "]
        subgraph FE_SVC ["  📦  Frontend Service  "]
            FE["⚛️ Next.js · React · TypeScript\nTailwindCSS · Framer Motion\nRecharts · AWS Amplify\nSentry · Jest · Playwright"]:::app
        end
        subgraph BE_SVC ["  🔧  Backend Service  "]
            ALB_BE["🔀 ALB — Backend\nInternal"]:::aws
            BE["🐍 FastAPI · Python · Uvicorn\nPydantic · boto3 · httpx\nredis-py · OpenTelemetry\nSentry · guardrails-ai"]:::app
        end
        subgraph WK_SVC ["  🤖  Worker Service (Fargate Spot)  "]
            WK["⚙️ Python · asyncio\nLangGraph · LangChain\nopenai · langsmith\nboto3 · redis-py\nOpenTelemetry · Sentry\nguardrails-ai · Trivy"]:::app
        end
    end

    %% ── QUEUE ────────────────────────────────────────────────────────
    subgraph QUEUE_BOX ["  📨  Message Queue  "]
        SQS["📬 SQS FIFO\nscan-jobs.fifo\nGroupId = repo_id"]:::queue
        DLQ["💀 Dead-Letter Queue\n3 retries · 14-day retention"]:::queue
    end

    %% ── SCANNING ─────────────────────────────────────────────────────
    subgraph SCAN ["  🔍  Security Scanning  "]
        TRIVY["🛡️ Trivy\nVuln + Secret Scan\nLocal Binary"]:::scanner
        LAM_TRIVY["λ Trivy Lambda\nFallback Scanner"]:::aws
        INSPECTOR["🔎 AWS Inspector v2\nECR CVE Scan\nEPSS · KEV"]:::aws
        LAM_INSP["λ Inspector Trigger\nStart · Poll Scan"]:::aws
    end

    %% ── AI AGENTS ────────────────────────────────────────────────────
    subgraph AGENTS ["  🧠  LangGraph AI Agent Pipeline  "]
        ORCH["🎯 Orchestrator\nasyncio · LangGraph\nProgress Publisher"]:::agent
        subgraph PAR ["  ⟳  Phase 1 — Parallel (asyncio.gather)  "]
            CVE["🔒 CVE Analyst\nEPSS · KEV\nCVSS Ranking"]:::agent
            BLOAT["📦 Bloat Detective\nLayer Analysis\nSize Reduction"]:::agent
            BASE["🏗️ Base Image Strategist\nDistroless · Alpine\nUpgrade Recs"]:::agent
            COMP["✅ Compliance Checker\nCIS · NIST 800-53\nPCI-DSS"]:::agent
        end
        subgraph SEQ ["  →  Phase 2 — Sequential  "]
            DOPT["📝 Dockerfile Optimizer\nMulti-stage · Diff\nCache Optimization"]:::agent
            RISK["📊 Risk Scorer\nA–F Grade · CVSS\nTop 5 Actions"]:::agent
        end
    end

    %% ── REAL-TIME ────────────────────────────────────────────────────
    subgraph RT_BOX ["  📡  Real-time WebSocket  "]
        WSAPI["🔌 API Gateway WebSocket v2\n$connect · $disconnect · $default"]:::rt
        LAM_AUTH["λ WS JWT Authorizer\nCognito Validation"]:::aws
        LAM_WS["λ WebSocket Handler\nconnect · broadcast"]:::aws
    end

    %% ── DATA ─────────────────────────────────────────────────────────
    subgraph DATA ["  💾  Data & Storage  "]
        DDB[("🗄️ DynamoDB\nscan-jobs · scan-results\nws-connections · KMS")]:::store
        S3[("🪣 S3\nScan Reports\nGlacier Lifecycle · KMS")]:::store
        REDIS[("⚡ ElastiCache Redis\nSessions · Pub/Sub\nConnection Registry")]:::store
    end

    %% ── AWS SUPPORT ──────────────────────────────────────────────────
    subgraph SUPPORT ["  🔧  AWS Supporting Services  "]
        SECRETS["🔑 Secrets Manager\nOpenAI · LangSmith\nRegistry Credentials"]:::aws
        SES["📧 AWS SES\nScan Email Notifications"]:::aws
        CW["📋 CloudWatch\nLogs · Dashboards · Alarms\nSNS Alerts"]:::aws
        IAM["🛡️ IAM\nTask Roles · Lambda Roles\nGitHub OIDC Roles"]:::aws
    end

    %% ── SAAS ─────────────────────────────────────────────────────────
    subgraph SAAS ["  🌍  External SaaS  "]
        OPENAI("🤖 OpenAI GPT-4o\nAll 6 Agents\ntemperature=0"):::ext
        LANGSMITH("🔗 LangSmith\nRun Tracing\nPrompt Versioning"):::ext
        SENTRY_FE("🚨 Sentry\nFrontend Errors\nPerformance"):::ext
        SENTRY_BE("🚨 Sentry\nBackend · Worker\nExceptions"):::ext
        GRAFANA("📈 Grafana Cloud\nOTLP Metrics + Traces\nDashboards · Alerts"):::ext
    end

    %% ── CI/CD ────────────────────────────────────────────────────────
    subgraph CICD_BOX ["  🚀  CI / CD Pipeline  "]
        GH["⚙️ GitHub Actions\nTest → Build → Push → Deploy\nOIDC Auth · No Static Keys"]:::cicd
        TF["🏗️ Terraform\n14 Modules · Remote State\ndev · staging · prod"]:::cicd
        subgraph ECR_BOX ["  📦  ECR Registries  "]
            ECR_FE["📦 ECR\nfrontend"]:::aws
            ECR_BE["📦 ECR\nbackend"]:::aws
            ECR_WK["📦 ECR\nworker"]:::aws
        end
    end

    %% ═══════════════════════════════════════════════════════════════
    %%  CONNECTIONS
    %% ═══════════════════════════════════════════════════════════════

    USER        -->|"HTTPS"| R53
    R53         --> WAF
    WAF         --> ALB_FE
    ALB_FE      --> FE
    USER        -->|"Login / Register"| COGNITO

    FE          <-->|"Amplify SDK"| AMPLIFY
    AMPLIFY     <-->|"User Pools"| COGNITO

    FE          -->|"REST /api/v1/*"| ALB_BE
    FE          <-->|"WebSocket Progress"| WSAPI
    FE          -->|"Errors · Perf"| SENTRY_FE
    ALB_BE      --> BE

    BE          -->|"Verify JWT"| COGNITO
    BE          -->|"CRUD Jobs & Results"| DDB
    BE          -->|"Enqueue Scan Job"| SQS
    BE          -->|"Exceptions"| SENTRY_BE
    BE          -->|"OTLP Spans"| GRAFANA
    BE          -->|"Logs"| CW
    BE          -->|"Get API Keys"| SECRETS

    WSAPI       <-->|"$connect Auth"| LAM_AUTH
    WSAPI       <-->|"broadcast"| LAM_WS
    LAM_AUTH    -->|"Verify JWT"| COGNITO
    LAM_WS      <-->|"Sessions · Pub/Sub"| REDIS

    SQS         -->|"Long Poll"| WK
    SQS         -.->|"After 3 retries"| DLQ

    WK          -->|"Get API Keys"| SECRETS
    WK          -->|"Fetch & Update Jobs"| DDB

    WK          -->|"subprocess JSON"| TRIVY
    TRIVY       -.->|"Fallback"| LAM_TRIVY
    WK          -->|"Invoke"| LAM_INSP
    LAM_INSP    -->|"ECR Scan"| INSPECTOR

    WK          -->|"Orchestrate"| ORCH
    ORCH        -->|"trivy + inspector"| CVE
    ORCH        -->|"layer data"| BLOAT
    ORCH        -->|"manifest"| BASE
    ORCH        -->|"manifest + vulns"| COMP

    CVE & BLOAT & BASE & COMP  -->|"findings[ ]"| DOPT
    DOPT        -->|"findings + diff"| RISK

    CVE & BLOAT & BASE & COMP & DOPT & RISK  -->|"ainvoke GPT-4o"| OPENAI
    OPENAI      -.->|"Run Tracing"| LANGSMITH

    WK          -->|"Store Result"| DDB
    WK          -->|"Upload Report"| S3
    WK          -->|"Publish Progress"| WSAPI
    WK          -->|"Email"| SES
    WK          -->|"OTLP Metrics"| GRAFANA
    WK          -->|"Exceptions"| SENTRY_BE
    WK          -->|"Logs"| CW

    GH          -->|"Build & Push"| ECR_FE & ECR_BE & ECR_WK
    GH          -->|"Deploy"| ECS
    ECR_FE      -->|"Pull"| FE
    ECR_BE      -->|"Pull"| BE
    ECR_WK      -->|"Pull"| WK
    TF          -->|"Provision"| ECS & DATA & SUPPORT & RT_BOX & QUEUE_BOX & AUTH
    IAM         -->|"Grant Permissions"| WK & BE

