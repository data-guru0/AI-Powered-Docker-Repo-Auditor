    %% ═══════════════════════════════════════════════════════════════
    %%  CONNECTIONS
    %% ═══════════════════════════════════════════════════════════════

    %% ─── User → Entry ────────────────────────────────────────────────
    USER        -->|"HTTPS"| R53
    R53         --> WAF
    WAF         --> ALB_FE
    ALB_FE      --> FE
    USER        -->|"Login / Register\nSRP Auth · JWT"| COGNITO

    %% ─── Auth ────────────────────────────────────────────────────────
    FE          <-->|"Amplify SDK\nOAuth 2.0 Redirect"| AMPLIFY
    AMPLIFY     <-->|"User Pools\nToken Vend"| COGNITO

    %% ─── Frontend → Backend ──────────────────────────────────────────
    FE          -->|"REST  /api/v1/*\nJWT Bearer Token"| ALB_BE
    FE          <-->|"WebSocket\nReal-time Progress"| WSAPI
    FE          -->|"Browser Errors\nWeb Vitals"| SENTRY_FE
    ALB_BE      --> BE

    %% ─── Backend Core ────────────────────────────────────────────────
    BE          -->|"Verify JWT\nPublic Key Fetch"| COGNITO
    BE          -->|"CRUD scan-jobs\nscan-results · ws-connections"| DDB
    BE          -->|"Enqueue Scan Job\nMessageGroupId = repo_id"| SQS
    BE          -->|"Python Exceptions\nFastAPI Errors"| SENTRY_BE
    BE          -->|"OTLP Spans\nMetrics"| GRAFANA
    BE          -->|"Structured Logs\n/ecs/backend"| CW
    BE          -->|"GetSecretValue\nUser Credentials"| SECRETS

    %% ─── WebSocket Layer ─────────────────────────────────────────────
    WSAPI       <-->|"$connect\nJWT Auth"| LAM_AUTH
    WSAPI       <-->|"$disconnect\nbroadcast"| LAM_WS
    LAM_AUTH    -->|"Verify JWT\nAllow/Deny"| COGNITO
    LAM_WS      <-->|"Connection IDs\nPub/Sub"| REDIS

    %% ─── Queue → Worker ──────────────────────────────────────────────
    SQS         -->|"Long Poll 20s\nVisibility 900s"| WK
    SQS         -.->|"After 3 retries"| DLQ

    %% ─── Worker Bootstrap ────────────────────────────────────────────
    WK          -->|"GetSecretValue\nOpenAI + LangSmith"| SECRETS
    WK          -->|"Fetch prev scan\nUpdate job status"| DDB

    %% ─── Scanning ────────────────────────────────────────────────────
    WK          -->|"subprocess · JSON\n--timeout 10m"| TRIVY
    TRIVY       -.->|"Fallback\nbinary missing"| LAM_TRIVY
    WK          -->|"Invoke Lambda"| LAM_INSP
    LAM_INSP    -->|"ECR image scan\nCVE findings"| INSPECTOR

    %% ─── Agent Orchestration ─────────────────────────────────────────
    WK          -->|"scan data\norchestrate agents"| ORCH
    ORCH        -->|"trivy_results\ninspector_findings"| CVE
    ORCH        -->|"layer_data\nmanifest"| BLOAT
    ORCH        -->|"manifest\nbase_image"| BASE
    ORCH        -->|"manifest +\ntrivy results"| COMP

    %% ─── Sequential Pipeline ─────────────────────────────────────────
    CVE & BLOAT & BASE & COMP  -->|"findings[ ]"| DOPT
    DOPT        -->|"all_findings +\ndockerfile diff"| RISK

    %% ─── LLM Calls ────────────────────────────────────────────────────
    CVE & BLOAT & BASE & COMP & DOPT & RISK  -->|"ainvoke  gpt-4o\ntemperature=0"| OPENAI
    OPENAI      -.->|"Run Tracing\nPrompt Versions"| LANGSMITH

    %% ─── Results & Notifications ─────────────────────────────────────
    WK          -->|"store_scan_result\nA–F Grade + JSON"| DDB
    WK          -->|"upload_scan_report\nFull JSON report"| S3
    WK          -->|"publish_progress\n10% → 100%"| WSAPI
    WK          -->|"Scan Completed\nHTML Email"| SES
    WK          -->|"OTLP · agent durations\nCVE counters · latency"| GRAFANA
    WK          -->|"Worker Exceptions\nAgent Errors"| SENTRY_BE
    WK          -->|"Structured Logs\n/ecs/worker"| CW

    %% ─── CI/CD ────────────────────────────────────────────────────────
    GH          -->|"docker build · push\nmulti-stage · cache"| ECR_FE & ECR_BE & ECR_WK
    GH          -->|"ecs update-service\nforce-new-deployment"| ECS
    ECR_FE      -->|"image pull"| FE
    ECR_BE      -->|"image pull"| BE
    ECR_WK      -->|"image pull"| WK
    TF          -->|"terraform apply\nIaC provision"| ECS & DATA & SUPPORT & RT_BOX & QUEUE_BOX & AUTH
    IAM         -->|"Task Role\ngrant permissions"| WK & BE

    %% ─── Observability ────────────────────────────────────────────────
    CW          -.->|"Metrics feed\nTrace correlation"| XRAY
